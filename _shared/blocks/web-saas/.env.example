# =============================================================================
# .env.example — modèle de variables d'environnement (safety-rails §4)
# Copier vers .env puis renseigner. NE JAMAIS committer de vraie valeur ici :
# ce fichier ne contient QUE des clés VIDES + un commentaire. .env est gitignore.
# =============================================================================

# --- Shell / SEO -------------------------------------------------------------
# URL publique canonique du site (sans slash final). Sert au SEO, aux liens
# absolus (emails, sitemap, OpenGraph) et aux redirect URLs OAuth.
NEXT_PUBLIC_SITE_URL=

# --- Auth / CRUD (Supabase) --------------------------------------------------
# URL du projet Supabase (https://xxxx.supabase.co).
NEXT_PUBLIC_SUPABASE_URL=
# Clé anon publique (safe côté navigateur, protégée par la RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service role — SERVEUR UNIQUEMENT, bypass la RLS. Jamais exposée au client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Notifications (Resend) --------------------------------------------------
# Clé API Resend (secret, à remplir). Sert AUX DEUX flux d'email, depuis le même
# domaine d'envoi générique : (a) transactionnel via l'API Resend (bloc
# notifications / lib/email) ET (b) confirmation de compte via le SMTP custom de
# Supabase Auth (posé en autonomie par provisioner-db). Jamais commitée.
RESEND_API_KEY=
# Adresse d'expédition générique par défaut : noreply@<domain> (domaine
# d'envoi générique mail.<domain>, vérifié une fois, réutilisé par tous les
# projets). Non secret. Un nom d'affichage optionnel peut préfixer l'adresse
# (ex. "FluentSpeech <noreply@fluentspeech.com>").
EMAIL_FROM=noreply@<domain>

# --- Observability (Sentry + PostHog) ----------------------------------------
# DSN public Sentry (capture d'erreurs client + serveur).
NEXT_PUBLIC_SENTRY_DSN=
# Token d'auth Sentry — SERVEUR/CI uniquement, pour l'upload des source maps.
SENTRY_AUTH_TOKEN=
# Clé projet PostHog (analytics d'activation).
NEXT_PUBLIC_POSTHOG_KEY=
# Host de l'instance PostHog (ex. https://eu.posthog.com).
NEXT_PUBLIC_POSTHOG_HOST=

# --- Billing (Stripe) — OPTIONNEL (seulement si le projet vend) --------------
# Clé secrète Stripe — SERVEUR UNIQUEMENT.
STRIPE_SECRET_KEY=
# Secret de signature du webhook Stripe (whsec_...).
STRIPE_WEBHOOK_SECRET=
# Clé publiable Stripe (safe côté navigateur).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Identifiant du prix par défaut à facturer (price_...).
STRIPE_PRICE_ID=
